{
	"name": "howles.dev",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vp dev",
		"build": "vp build && cp dist/index.html dist/404.html",
		"preview": "vp preview",
		"test:unit": "vp test",
		"test:unit:ui": "vp test --ui",
		"test:unit:run": "vp test run",
		"test:component": "cypress run --component",
		"test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
		"lint": "eslint . --fix",
		"deploy": "bun run build; gh-pages -d dist --cname howles.dev",
		"prepare": "vp config"
	},
	"dependencies": {
		"@lewishowles/components": "^2.0.3",
		"@lewishowles/helpers": "^0.19.0",
		"@vueuse/core": "^14.3.0",
		"pinia": "^3.0.4",
		"unplugin-vue-components": "^32.1.0",
		"vue": "^3.5.35",
		"vue-i18n": "^11.4.5",
		"vue-router": "^5.1.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@lewishowles/testing": "^0.10.0",
		"@pinia/testing": "^1.0.3",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/postcss": "^4.3.0",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vitest/ui": "^4.1.8",
		"@vue/test-utils": "^2.4.11",
		"cypress": "^15.16.0",
		"cypress-real-events": "^1.15.0",
		"eslint-plugin-cypress": "^6.4.1",
		"gh-pages": "^6.3.0",
		"globals": "^17.6.0",
		"happy-dom": "^20.10.2",
		"start-server-and-test": "^3.0.8",
		"tailwindcss": "^4.3.0",
		"tailwindcss-hocus": "^1.0.0",
		"vite": "npm:@voidzero-dev/vite-plus-core@latest",
		"vite-plugin-vue-devtools": "^8.1.2",
		"vite-plus": "latest",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest"
	},
	"overrides": {
		"vite": "npm:@voidzero-dev/vite-plus-core@latest",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest"
	},
	"packageManager": "bun@1.3.14"
}
